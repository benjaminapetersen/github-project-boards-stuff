# ============================================================================
# kube-board environment configuration
# ============================================================================
# Copy to .env/kube-board.env and fill in your values:
#   cp .env/kube-board.env.example .env/kube-board.env
# Then load before running:
#   source .env/kube-board.env
# ============================================================================

# ---- Authentication ----
# Required: Classic PAT with read:org, read:project, repo, project scopes.
# Fine-grained (modern) tokens do NOT work with the Projects V2 API.
#
# Check your token authorized to write to your board with:
# (SSO authorization for your PAT may be necessary for your org)
# curl -s -H "Authorization: bearer $GITHUB_TOKEN" https://api.github.com/{users||orgs}/{username||orgname} | jq '.login, .id'
export GITHUB_TOKEN=ghp_your_token_here

# ---- Team Members ----
# Comma-separated GitHub usernames.
# Combine core team + others of interest into one list.
# Shell variable composition is supported for organization.
#
# CORE_TEAM=enj,aramase,ritazh,stlaz
# OTHERS_OF_INTEREST=liggitt,tallclair,ahmedtd
# export GITHUB_USERNAMES="${CORE_TEAM},${OTHERS_OF_INTEREST}"
#
export GITHUB_USERNAMES=enj,aramase,ritazh,stlaz,liggitt,tallclair,ahmedtd

# ---- Tiered User Scoping (new 3-path OR query approach) ----
# When GITHUB_CORE_USERNAMES is set, the issues phase uses org-wide OR queries
# instead of the legacy repo+label AND approach. This solves several problems:
#   - Catches merged PRs (no state:open filter)
#   - Searches all repos in each org (not just kubernetes/kubernetes)
#   - Uses OR logic: label queries + user queries run independently
#
# Core users get "involves:" queries — catches everything they touch.
# Extended users get "author:" + "assignee:" only — avoids pulling in
# every issue a prolific reviewer (e.g., liggitt) ever commented on.
#
# CORE_TEAM=enj,aramase,ritazh,stlaz
# OTHERS_OF_INTEREST=liggitt,tallclair,ahmedtd
# export GITHUB_CORE_USERNAMES="${CORE_TEAM}"
# export GITHUB_EXTENDED_USERNAMES="${OTHERS_OF_INTEREST}"
#
# When these are NOT set, the legacy buildIssueQueries path is used
# (backward compatible — no behavior change).
# export GITHUB_CORE_USERNAMES=
# export GITHUB_EXTENDED_USERNAMES=

# ---- Additional Organizations (comma-separated, optional) ----
# The kubernetes org is always included as the primary target.
# List additional orgs here to search for team members' issues/PRs.
# kubernetes can be listed but will be deduplicated automatically.
export GITHUB_ADDITIONAL_ORGS=kubernetes-sigs,Azure

# ---- sync-enhancement-board Phase ----
# This phase discovers KEPs from the enhancements repo and enriches them
# with tracking fields from the official enhancements tracking board (#241).

# Repo containing KEPs (default: kubernetes/enhancements)
# export ENHANCEMENTS_REPO=kubernetes/enhancements

# Labels to search for enhancement issues (comma-separated, default: sig/auth)
# export ENHANCEMENTS_LABELS=sig/auth

# Kubernetes milestone to filter enhancement searches (optional, applied server-side)
export GITHUB_KUBERNETES_MILESTONE=v1.36

# Source board to sync fields from. Format: org/projects/number
# (default: kubernetes/projects/241 — the official enhancements board)
export GITHUB_KUBERNETES_RELEASE_SYNC_BOARD="kubernetes/projects/241"

# Comma-separated field keys to sync from the source board to the destination.
#
# Well-known keys (with source→dest column name mapping):
#   TrackingStatus  → "Tracking Status"  (source: "Status")
#   Stage           → "Stage"
#   PRRStatus       → "PRR Status"
#   EnhancementType → "Enhancement Type"
#   SIG             → "SIG"
#   Milestone       → "Milestone"
#
# Passthrough keys: Any other key is treated as a passthrough — the key itself
# is used as both the source and destination column name. The field type
# (text, single-select, etc.) is auto-detected from the source board.
#
# Examples of passthrough keys from board #241:
#   "Blog Status", "PRR Assignee", "PRR Shadow", "PRR Notes",
#   "Doc Status", "Docs PR", "Docs Required?", "Docs Assignee",
#   "Blog PR", "Blog writing buddy", "Comms notes", etc.
#
# Shell variable composition is supported for organization:
# KUBE_BASIC="TrackingStatus,Stage,EnhancementType,SIG,Milestone"
# KUBE_PRR="PRRStatus,PRR Assignee,PRR Shadow,PRR Notes"
# KUBE_DOCS="Doc Status,Docs PR,Docs Required?,Docs Assignee"
# export GITHUB_KUBERNETES_RELEASE_SYNC_BOARD_FIELDS="${KUBE_BASIC},${KUBE_PRR},${KUBE_DOCS}"
#
export GITHUB_KUBERNETES_RELEASE_SYNC_BOARD_FIELDS="TrackingStatus,Stage,PRRStatus,EnhancementType,SIG,Milestone"

# ---- sync-org-items Phase ----
# This phase searches across orgs for issues/PRs by team members.

# Repo to search for issues/PRs (default: kubernetes/kubernetes)
# export ISSUES_REPO=kubernetes/kubernetes

# SIG labels for issue/PR searching (comma-separated).
#
# Legacy behavior (GITHUB_CORE_USERNAMES NOT set):
#   Narrowing filter — combined with per-user involves: queries in the kubernetes org.
#   Critical for prolific contributors who would otherwise return huge result sets.
#
# New 3-path OR behavior (GITHUB_CORE_USERNAMES IS set):
#   Org-wide label queries — "org:<ORG> label:<LABEL>" with no user qualifier.
#   Catches ALL items with these labels, regardless of author. Run independently
#   alongside user-specific queries (OR logic, not AND).
#
# Supports multiline with commas:
# export GITHUB_KUBERNETES_ISSUES_SIG_LABELS="
# sig/auth,
# sig/security,
# sig/node
# "
export GITHUB_KUBERNETES_ISSUES_SIG_LABELS=sig/auth

# Search qualifier: "involves" (broadest, default), "author", or "assignee"
# export ISSUES_SEARCH_QUALIFIER=involves

# How far back to search for items.
#
# Legacy behavior: Only applied to additional orgs (kubernetes-sigs, Azure).
#   The primary repo uses state:open + milestone instead.
#
# New 3-path OR behavior (GITHUB_CORE_USERNAMES set): Applied to ALL queries.
#   Replaces state:open to capture merged PRs & closed issues within the window.
#   Recommended: set to your planning horizon (e.g., 6m for current cycle).
#
# Format: Nd (days), Nw (weeks), Nm (months), Ny (years). Default: not set.
# export GITHUB_SEARCH_SINCE=6m

# Two-tier recency filter for closed/merged items.
#
# When set, all OPEN items are always kept regardless of age.
# CLOSED and MERGED items are kept only if updated within this window.
# Applied client-side after search results are collected.
#
# This is useful with a broad GITHUB_SEARCH_SINCE (e.g., 2y) to cast a wide
# net for open items while trimming old closed/merged noise.
#
# Format: Nd (days), Nw (weeks), Nm (months), Ny (years). Default: 0 (keep all).
# export GITHUB_CLOSED_ITEM_WINDOW=1m

# ---- Exclusion Filters ----
# States to exclude from search (applied server-side, default: closed)
export GITHUB_EXCLUDE_STATES=closed

# Labels to exclude (applied server-side as -label:)
export GITHUB_EXCLUDE_LABELS=lifecycle/stale,lifecycle/rotten

# Board statuses to exclude (applied client-side after enrichment).
# These match the "Status" field values from the source enhancements board.
# export GITHUB_EXCLUDE_STATUSES=Deferred,Removed from Milestone

# Item types to include (optional, comma-separated: issue, pr)
# export GITHUB_ITEM_TYPES=issue,pr

# ---- Destination Board ----
# Only needed when using --output=board.
# The board will be created at https://github.com/orgs/{owner}/projects/{id}
# (or users/{owner}/projects/{id} for personal accounts).

# User/org owning the destination board
export GITHUB_DEST_BOARD_OWNER=your-github-org

# Name for the destination board
export GITHUB_DEST_BOARD_NAME="SIG Auth 1.36 Team Board"

# Board visibility: "private" (default) or "public"
export GITHUB_DEST_BOARD_PRIVACY=private

# ---- Automatic Fields ----
# The following fields are ALWAYS created on the destination board automatically.
# No configuration is needed — they are populated for every item:
#
#   Item Author  (TEXT)   — GitHub username of the issue/PR creator
#                           ("Author" is reserved by GitHub Projects, so we use "Item Author")
#   Last Updated (DATE)   — Date the item was last updated (YYYY-MM-DD)
#                           Native DATE type enables date filtering/sorting in views
#   Source       (SELECT) — "enhancements" or "issues" (which phase found the item)
#
# Override the Author field name if desired (default: "Item Author"):
# export GITHUB_DEST_BOARD_AUTHOR_FIELD_NAME="Item Author"

# ---- Custom Fields ----
# Additional fields to auto-create on the destination board.
# Format: Name:Opt1|Opt2|Opt3, Name2
#   - Comma separates fields
#   - Colon separates name from single-select options
#   - Pipe separates option values
#   - No colon = TEXT field
#
# Example with shell variable composition:
# STATUS="Status:🆕 New|📋 Backlog|🔖 Ready|🛑 Blocked|🏗 In progress|✅ Done"
# STREAM="Stream:Upstream|Downstream|-"
# PRIORITY="Priority:P0|P1|P2|P3"
# export GITHUB_DEST_BOARD_CUSTOM_FIELDS="${STATUS},${STREAM},${PRIORITY},Notes"
#
# export GITHUB_DEST_BOARD_CUSTOM_FIELDS="Stream:Upstream|Downstream,Priority:P0|P1|P2|P3,Notes"

# ---- Views ----
# View names to auto-create on the destination board (one per line).
# Format: ViewName=Field1,Field2,Field3
#   - "=" separates view name from visible field names (comma-separated)
#   - No "=" creates the view with default columns
# Views are created via the REST API for reliability.
# Existing view filters are NOT overwritten — only new views are created.
#
# Shell variable composition works for shared column groups:
# TRIMESTER="Epic,Bet,Stream"
# export GITHUB_DEST_BOARD_ADDITIONAL_VIEWS="
# KEPs=${TRIMESTER},Tracking Status,Stage,PRR Status,SIG,Milestone
# Current Issues=${TRIMESTER},Notes
# Done Last Month=Last Updated,Item Author,Notes
# PRR=PRR Status,PRR Assignee,PRR Shadow,PRR Notes
# "
#
# export GITHUB_DEST_BOARD_ADDITIONAL_VIEWS=""

# ---- Auto-Assign Rules ----
# Automatically set custom field values based on which repo an item belongs to.
# One rule per line: FieldName:Value=repo_glob,repo_glob
# Glob patterns match against "owner/name" (supports * and ?).
# First matching rule wins for each field.
# Only applied when the item doesn't already have a value for that field.
#
# export GITHUB_AUTO_CUSTOM_FIELD_TO_REPO="
# Stream:Upstream=kubernetes/*,kubernetes-sigs/*
# Stream:Downstream=Azure/*
# Priority:P1=kubernetes/kubernetes
# "

# ---- Linked Repos ----
# Repos to link to the destination board (comma-separated).
# Boards exist at a user/org level by default; linking makes them
# appear in the repo's "Projects" sidebar.
# export GITHUB_LINK_REPOS=enhancements,kubernetes
